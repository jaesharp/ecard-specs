{
  "name": "ecard-specs-tools",
  "version": "1.0.0",
  "private": true,
  "description": "Formatting and validation tools for ecard-specs",
  "scripts": {
    "test": "cd .. && npx --prefix tools prettier --check '**/*.md' '**/*.feature'",
    "format": "cd .. && npx --prefix tools prettier --write '**/*.md' '**/*.feature'"
  },
  "devDependencies": {
    "prettier": "^3.8.3",
    "prettier-plugin-gherkin": "^3.1.3"
  }
}
